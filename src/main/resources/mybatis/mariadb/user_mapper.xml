<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.metacoding.blog.entity.UserEntity">

	<insert id="insert" parameterType="com.study.metacoding.blog.entity.UserEntity">
		INSERT INTO USER (			
			NAME,
			PASSWORD,	
			EMAIL,
			ROLE
		) VALUES (
			#{name},
			#{password},	
			#{email},
			#{role}
		)
	</insert>

	<select id="selectUser" parameterType="Long" resultType="com.study.metacoding.blog.entity.UserEntity">
		SELECT			
			NAME,
			PASSWORD,	
			EMAIL,
			ROLE
		FROM USER
		WHERE ID = #{id}
	</select>
	
	<select id="selectAll" resultType="com.study.metacoding.blog.entity.UserEntity">
		SELECT			
			NAME,
			PASSWORD,	
			EMAIL,
			ROLE
		FROM USER
	</select>
	
	<!-- <update id="updateSeq" parameterType="Long">
		UPDATE BOARD
			SET HITS = HITS+1
		WHERE SEQ = #{seq}
	</update> -->
	
</mapper>
